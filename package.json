{
  "name": "karin",
  "version": "0.1.0",
  "displayVersion": "v.90",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "description": "Karin \u00c3\u00a2\u00e2\u201a\u00ac\u00e2\u20ac\u009d local Codex session viewer. React 19 + Vite + TS + Tailwind v4. Load-your-own data; transcripts never leave your machine.",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:local": "tsc --noEmit && vite build --mode offline",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "index": "python bin/karin.py",
    "index:watch": "python bin/karin.py --watch",
    "index:claude": "python bin/karin_claude.py",
    "index:claude:watch": "python bin/karin_claude.py --watch",
    "index:warp": "python bin/karin_warp.py",
    "index:warp:watch": "python bin/karin_warp.py --watch"
  },
  "dependencies": {
    "@adomas/json-tree": "file:../json-tree",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "clsx": "^2.1.1",
    "lucide-react": "^0.474.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.5",
    "tailwind-merge": "^3.0.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.6",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.6",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
